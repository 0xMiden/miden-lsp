{
  "name": "miden-vscode-extension",
  "displayName": "Miden",
  "description": "VS Code support for Miden Assembly via miden-lsp.",
  "version": "0.1.0",
  "license": "MIT OR Apache-2.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/0xpolygonmiden/miden-lsp"
  },
  "engines": {
    "vscode": "^1.97.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "miden",
    "masm",
    "lsp",
    "language-server"
  ],
  "activationEvents": [
    "onLanguage:masm",
    "workspaceContains:miden-project.toml",
    "onCommand:miden-lsp.restartServer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "masm",
        "aliases": [
          "Miden Assembly",
          "MASM"
        ],
        "extensions": [
          ".masm"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "masm",
        "scopeName": "source.masm",
        "path": "./syntaxes/masm.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "miden-lsp.restartServer",
        "title": "Miden: Restart Language Server"
      }
    ],
    "configuration": {
      "title": "Miden LSP",
      "properties": {
        "miden-lsp.binary.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to the `miden-lsp` executable. When empty, the extension resolves `miden-lsp` from `PATH`."
        },
        "miden-lsp.binary.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Additional command-line arguments passed to `miden-lsp`."
        },
        "miden-lsp.binary.env": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "string"
          },
          "markdownDescription": "Extra environment variables merged into the `miden-lsp` process environment."
        },
        "miden-lsp.initializationOptions": {
          "type": "object",
          "default": {},
          "markdownDescription": "Initialization options forwarded to `miden-lsp` during client startup."
        },
        "miden-lsp.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "markdownDescription": "Trace level for `miden-lsp` protocol logging in the output panel."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.2.0",
    "@types/vscode": "^1.97.0",
    "typescript": "^5.8.3"
  }
}
