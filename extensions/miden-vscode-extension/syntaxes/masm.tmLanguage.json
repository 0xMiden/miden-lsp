{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Miden Assembly",
  "scopeName": "source.masm",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#control"
    },
    {
      "include": "#visibility"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.masm",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.masm",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.masm"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.masm"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.masm",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.masm",
          "match": "\\b(?:0x[0-9A-Fa-f_]+|0b[01_]+|\\d[\\d_]*)\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "keyword.declaration.masm",
          "match": "\\b(?:use|const|proc|type|enum|struct|begin|end)\\b"
        }
      ]
    },
    "control": {
      "patterns": [
        {
          "name": "keyword.control.masm",
          "match": "\\b(?:if(?:\\.true)?|else|while(?:\\.true)?|repeat|exec|call|syscall|procref|dyncall|dynexec)\\b"
        }
      ]
    },
    "visibility": {
      "patterns": [
        {
          "name": "storage.modifier.masm",
          "match": "\\bpub\\b"
        }
      ]
    }
  }
}
